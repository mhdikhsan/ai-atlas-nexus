            owl:onProperty nexus:hasCapability ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:implementsCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        nexus:Entry ;
    skos:definition "A capability that can be invoked through a well-defined API that is reasonably stable and independent of how the LLM intrinsic itself is implemented." ;
    skos:exactMatch <https://w3id.org/dpv/ai#Capability> ;
    skos:inScheme nexus:ai_intrinsic .

nexus:Modality a owl:Class ;
    rdfs:label "Modality" ;
    rdfs:subClassOf nexus:Entity ;
    skos:definition "A modality supported by an Ai component. Examples include text, image, video." ;
    skos:exactMatch airo:Modality ;
    skos:inScheme nexus:ai_system .

nexus:detectsRiskConcept a owl:ObjectProperty ;
    rdfs:label "detectsRiskConcept" ;
    rdfs:domain nexus:RiskControl ;
    rdfs:range nexus:RiskConcept ;
    owl:inverseOf nexus:isDetectedBy ;
    skos:definition "The property airo:detectsRiskConcept indicates the control used for detecting risks, risk sources, consequences, and impacts." ;
    skos:exactMatch airo:detectsRiskConcept ;
    skos:inScheme nexus:ai_risk .

nexus:implementsCapability a owl:ObjectProperty ;
    rdfs:label "implementsCapability" ;
    rdfs:domain nexus:Any ;
    rdfs:range nexus:Capability ;
    skos:definition "Indicates that this entity implements a specific capability" ;
    skos:inScheme nexus:common .

nexus:requiredByTask a owl:ObjectProperty ;
    rdfs:label "requiredByTask" ;
    rdfs:range nexus:AiTask ;
    owl:inverseOf nexus:requiresCapability ;
    skos:definition "Indicates that this entry is required to perform a specific AI task." ;
    skos:inScheme nexus:common .

nexus:AIUC1EvidenceCategory a owl:Class ;
    rdfs:label "AIUC1EvidenceCategory" ;
    owl:unionOf ( <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#TECHNICAL_IMPLEMENTATION> <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#LEGAL_POLICIES> <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#OPERATIONAL_PRACTICES> <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#THIRD_PARTY_EVALS> ) ;
    skos:inScheme nexus:ai_aiuc ;
    linkml:permissible_values <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#LEGAL_POLICIES>,
        <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#OPERATIONAL_PRACTICES>,
        <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#TECHNICAL_IMPLEMENTATION>,
        <https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#THIRD_PARTY_EVALS> .

nexus:Adapter a owl:Class ;
    rdfs:label "Adapter" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:requiresCapability ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:requiresCapability ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:implementsCapability ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:implementsCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AdapterType ;
            owl:onProperty nexus:hasAdapterType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:adaptsModel ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasAdapterType ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:hasCapability ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LargeLanguageModel ;
            owl:onProperty nexus:adaptsModel ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:License ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Vocabulary ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
            owl:onProperty nexus:hasRelatedRisk ],
        nexus:Entry,
        nexus:LargeLanguageModel ;
    skos:definition "Adapter-based methods add extra trainable parameters after the attention and fully-connected layers of a frozen pretrained model to reduce memory-usage and speed up training. The adapters are typically small but demonstrate comparable performance to a fully finetuned model and enable training larger models with fewer resources. (https://huggingface.co/docs/peft/en/conceptual_guides/adapter)" ;
    skos:inScheme nexus:ai_intrinsic .

nexus:CapabilityConcept a owl:Class ;
    rdfs:label "CapabilityConcept" ;
