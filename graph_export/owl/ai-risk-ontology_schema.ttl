@prefix airo: <https://w3id.org/airo#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix nexus: <https://w3id.org/ai-atlas-nexus/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nexus:AiOffice a owl:Class ;
    rdfs:label "AiOffice" ;
    rdfs:subClassOf nexus:Organization ;
    skos:definition "The EU AI Office (https://digital-strategy.ec.europa.eu/en/policies/ai-office)" ;
    skos:exactMatch <http://schema.org/Organization> ;
    skos:inScheme nexus:eu_ai_act .

nexus:Container a owl:Class ;
    rdfs:label "Container" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Permission ;
            owl:onProperty nexus:permissions ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LargeLanguageModel ;
            owl:onProperty nexus:aimodels ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:licenses ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:aitasks ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:aimodelfamilies ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Stakeholder ;
            owl:onProperty nexus:stakeholders ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:adapters ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LargeLanguageModelFamily ;
            owl:onProperty nexus:aimodelfamilies ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiEvalResult ;
            owl:onProperty nexus:aievalresults ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Action ;
            owl:onProperty nexus:actions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:riskincidents ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:StakeholderGroup ;
            owl:onProperty nexus:stakeholdergroups ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:groups ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:permissions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:concepts ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Rule ;
            owl:onProperty nexus:rules ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Organization ;
            owl:onProperty nexus:organizations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:benchmarkmetadatacards ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:llmintrinsics ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LLMIntrinsic ;
            owl:onProperty nexus:llmintrinsics ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiTask ;
            owl:onProperty nexus:aitasks ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Obligation ;
            owl:onProperty nexus:obligations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:stakeholdergroups ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Modality ;
            owl:onProperty nexus:modalities ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:taxonomies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:prohibitions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:documents ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:organizations ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiEval ;
            owl:onProperty nexus:evaluations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:obligations ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:taxonomies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:entries ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Control ;
            owl:onProperty nexus:controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Prohibition ;
            owl:onProperty nexus:prohibitions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:aievalresults ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:rules ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:vocabularies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:stakeholders ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:modalities ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:License ;
            owl:onProperty nexus:licenses ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Policy ;
            owl:onProperty nexus:policies ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:actions ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:aimodels ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Vocabulary ;
            owl:onProperty nexus:vocabularies ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Adapter ;
            owl:onProperty nexus:adapters ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Concept ;
            owl:onProperty nexus:concepts ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:evaluations ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:documents ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Entry ;
            owl:onProperty nexus:entries ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Dataset ;
            owl:onProperty nexus:datasets ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:policies ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:BenchmarkMetadataCard ;
            owl:onProperty nexus:benchmarkmetadatacards ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Group ;
            owl:onProperty nexus:groups ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:RiskIncident ;
            owl:onProperty nexus:riskincidents ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:datasets ] ;
    skos:definition "An umbrella object that holds the ontology class instances" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:IncidentConcludedclass a owl:Class ;
    rdfs:label "IncidentConcludedclass" ;
    rdfs:subClassOf nexus:IncidentStatus ;
    skos:exactMatch <https://w3id.org/dpv#IncidentConcludedclass> ;
    skos:inScheme nexus:ai_risk .

nexus:IncidentHaltedclass a owl:Class ;
    rdfs:label "IncidentHaltedclass" ;
    rdfs:subClassOf nexus:IncidentStatus ;
    skos:exactMatch <https://w3id.org/dpv#IncidentHaltedclass> ;
    skos:inScheme nexus:ai_risk .

nexus:IncidentMitigatedclass a owl:Class ;
    rdfs:label "IncidentMitigatedclass" ;
    rdfs:subClassOf nexus:IncidentStatus ;
    skos:exactMatch <https://w3id.org/dpv#IncidentMitigatedclass> ;
    skos:inScheme nexus:ai_risk .

nexus:IncidentNearMissclass a owl:Class ;
    rdfs:label "IncidentNearMissclass" ;
    rdfs:subClassOf nexus:IncidentStatus ;
    skos:exactMatch <https://w3id.org/dpv#IncidentNearMissclass> ;
    skos:inScheme nexus:ai_risk .

nexus:IncidentOngoingclass a owl:Class ;
    rdfs:label "IncidentOngoingclass" ;
    rdfs:subClassOf nexus:IncidentStatus ;
    skos:exactMatch <https://w3id.org/dpv#IncidentOngoingclass> ;
    skos:inScheme nexus:ai_risk .

nexus:Input a owl:Class ;
    rdfs:label "Input" ;
    rdfs:subClassOf nexus:Entity ;
    skos:definition "Input for which the system or component generates output." ;
    skos:exactMatch airo:Input ;
    skos:inScheme nexus:ai_system .

nexus:Questionnaire a owl:Class ;
    rdfs:label "Questionnaire" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Question ;
            owl:onProperty nexus:composed_of ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:composed_of ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:composed_of ],
        nexus:AiEval ;
    skos:definition "A questionnaire groups questions" ;
    skos:inScheme nexus:ai_eval .

nexus:ai-risk-ontology.owl.ttl a owl:Ontology ;
    rdfs:label "ai-risk-ontology" ;
    dcterms:license "https://www.apache.org/licenses/LICENSE-2.0.html" ;
    pav:version "0.5.0" ;
    skos:definition "An ontology describing AI systems and their risks" .

nexus:hasTerm a owl:ObjectProperty ;
    rdfs:label "hasTerm" ;
    rdfs:range nexus:Term ;
    skos:definition "Indicates terms associated with a vocabulary" ;
    skos:inScheme nexus:common .

nexus:implementedByIntrinsic a owl:ObjectProperty ;
    rdfs:label "implementedByIntrinsic" ;
    rdfs:range nexus:LLMIntrinsic ;
    owl:inverseOf nexus:implementsCapability ;
    skos:definition "Indicates that this capability is implemented by a specific LLM intrinsic. This relationship distinguishes the abstract capability (what can be done) from the technical implementation mechanism (how it is done at the model component level)." ;
    skos:inScheme nexus:ai_capability .

nexus:isDistributedBy a owl:ObjectProperty ;
    rdfs:label "isDistributedBy" ;
    rdfs:range nexus:Organization ;
    skos:definition "A relationship indicating that an entity has been distributed by an organization." ;
    skos:inScheme nexus:eu_ai_act .

nexus:isImportedBy a owl:ObjectProperty ;
    rdfs:label "isImportedBy" ;
    rdfs:range nexus:Organization ;
    skos:definition "A relationship indicating that an entity has been imported by an organization." ;
    skos:inScheme nexus:eu_ai_act .

nexus:isUsedBy a owl:ObjectProperty ;
    rdfs:label "isUsedBy" ;
    rdfs:range nexus:AiProvider ;
    skos:definition "Indicates user of an AI system." ;
    skos:inScheme nexus:ai_system .

nexus:possessedByAi a owl:ObjectProperty ;
    rdfs:label "possessedByAi" ;
    rdfs:domain nexus:Capability ;
    rdfs:range nexus:BaseAi ;
    owl:inverseOf nexus:hasCapability ;
    skos:definition "Indicates that this capability is possessed by a specific AI system or component. Inverse of hasCapability, allowing navigation from capabilities to AI systems. This enables queries like \"which AI systems have this capability?\"" ;
    skos:inScheme nexus:ai_capability .

nexus:training_data_preprocessing a owl:ObjectProperty ;
    rdfs:label "training_data_preprocessing" ;
    rdfs:range nexus:DataPreprocessing ;
    skos:definition "relationship indicating data preprocessing steps performed on training data sets to ensure high quality training data." ;
    skos:inScheme nexus:ai_system .

nexus:validated_by a owl:ObjectProperty ;
    rdfs:label "validated_by" ;
    rdfs:range nexus:AiModelValidation ;
    skos:definition "A relationship indicating the model validation steps after AI model training." ;
    skos:inScheme nexus:ai_system .

nexus:AIComponent a owl:Class ;
    rdfs:label "AIComponent" ;
    rdfs:subClassOf nexus:Entity ;
    skos:definition "Component (element) of an AI system" ;
    skos:exactMatch airo:AIComponent ;
    skos:inScheme nexus:ai_system .

nexus:AIOperator a owl:Class ;
    rdfs:label "AIOperator" ;
    rdfs:subClassOf nexus:Stakeholder ;
    skos:definition "Refers to a provider, product manufacturer, deployer, authorised representative, importer or distributor." ;
    skos:exactMatch airo:AIOperator ;
    skos:inScheme nexus:ai_system .

nexus:AiModel a owl:Class ;
    rdfs:label "AiModel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiEvalResult ;
            owl:onProperty nexus:hasEvaluation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:architecture ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:architecture ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:architecture ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasEvaluation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:power_consumption_w ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:RiskControl ;
            owl:onProperty nexus:hasRiskControl ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:power_consumption_w ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:gpu_hours ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty nexus:carbon_emitted ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty nexus:power_consumption_w ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:carbon_emitted ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:gpu_hours ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRiskControl ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:carbon_emitted ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty nexus:gpu_hours ],
        nexus:AIComponent,
        nexus:BaseAi ;
    skos:definition "A base AI Model class. No assumption about the type (SVM, LLM, etc.). Subclassed by model types (see LargeLanguageModel)." ;
    skos:inScheme nexus:ai_system .

nexus:AiModelValidation a owl:Class ;
    rdfs:label "AiModelValidation" ;
    rdfs:subClassOf nexus:AiLifecyclePhase ;
    skos:definition "AI model validation steps that have been performed after the model training to ensure high AI model quality." ;
    skos:inScheme nexus:ai_system .

nexus:DataPreprocessing a owl:Class ;
    rdfs:label "DataPreprocessing" ;
    rdfs:subClassOf nexus:AiLifecyclePhase ;
    skos:definition "Data transformations, such as PI filtering, performed to ensure high quality of AI model training data." ;
    skos:inScheme nexus:ai_system .

nexus:Fact a owl:Class ;
    rdfs:label "Fact" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty nexus:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:evidence ] ;
    skos:definition "A fact about something, for example the result of a measurement. In addition to the value, evidence is provided." ;
    skos:exactMatch <http://schema.org/Statement> ;
    skos:inScheme nexus:common .

nexus:Question a owl:Class ;
    rdfs:label "Question" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:text ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty nexus:text ],
        nexus:AiEval ;
    skos:definition "An evaluation where a question has to be answered" ;
    skos:inScheme nexus:ai_eval .

nexus:SlotCondition a owl:Class ;
    rdfs:label "SlotCondition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:equals_string ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:slot_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:slot_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:equals_string ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:slot_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:equals_string ] ;
    skos:inScheme nexus:common .

nexus:evaluatedByBenchmark a owl:ObjectProperty ;
    rdfs:label "evaluatedByBenchmark" ;
    rdfs:range nexus:BenchmarkMetadataCard ;
    owl:inverseOf nexus:evaluatesCapability ;
    skos:definition "Indicates that this capability is evaluated by a specific benchmark" ;
    skos:inScheme nexus:ai_capability .

nexus:evaluatesCapability a owl:ObjectProperty ;
    rdfs:label "evaluatesCapability" ;
    rdfs:domain nexus:BenchmarkMetadataCard ;
    rdfs:range nexus:Capability ;
    owl:inverseOf nexus:evaluatedByBenchmark ;
    skos:definition "Indicates that this benchmark evaluates a specific capability" ;
    skos:inScheme nexus:ai_capability .

nexus:AIDeployer a owl:Class ;
    rdfs:label "AIDeployer" ;
    rdfs:subClassOf nexus:AIOperator ;
    skos:definition "Any natural or legal person, public authority, agency or other body using an AI system under its authority except where the AI system is used in the course of a personal non-professional activity." ;
    skos:exactMatch airo:AIDeployer ;
    skos:inScheme nexus:ai_system .

nexus:AIDeveloper a owl:Class ;
    rdfs:label "AIDeveloper" ;
    rdfs:subClassOf nexus:Stakeholder ;
    skos:definition "An organisation or entity that is concerned with the development of AI services and products." ;
    skos:exactMatch airo:AIDeveloper ;
    skos:inScheme nexus:ai_system .

nexus:AISubject a owl:Class ;
    rdfs:label "AISubject" ;
    rdfs:subClassOf nexus:Stakeholder ;
    skos:definition "An entity that is subject to or impacted by the use of AI." ;
    skos:exactMatch airo:AISubject ;
    skos:inScheme nexus:ai_system .

<https://w3id.org/ai-atlas-nexus/AIUC1ApplicationCategory#MANDATORY> a owl:Class ;
    rdfs:label "MANDATORY" ;
    rdfs:subClassOf nexus:AIUC1ApplicationCategory ;
    skos:definition "Mandatory" .

<https://w3id.org/ai-atlas-nexus/AIUC1ApplicationCategory#OPTIONAL> a owl:Class ;
    rdfs:label "OPTIONAL" ;
    rdfs:subClassOf nexus:AIUC1ApplicationCategory ;
    skos:definition "Optional" .

<https://w3id.org/ai-atlas-nexus/AIUC1ControlApplicationCategory#CORE> a owl:Class ;
    rdfs:label "CORE" ;
    rdfs:subClassOf nexus:AIUC1ControlApplicationCategory ;
    skos:definition "Core Control" .

<https://w3id.org/ai-atlas-nexus/AIUC1ControlApplicationCategory#SUPPLEMENTAL> a owl:Class ;
    rdfs:label "SUPPLEMENTAL" ;
    rdfs:subClassOf nexus:AIUC1ControlApplicationCategory ;
    skos:definition "Supplemental Control" .

<https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#LEGAL_POLICIES> a owl:Class ;
    rdfs:label "LEGAL_POLICIES" ;
    rdfs:subClassOf nexus:AIUC1EvidenceCategory ;
    skos:definition "Legal Policies" .

<https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#OPERATIONAL_PRACTICES> a owl:Class ;
    rdfs:label "OPERATIONAL_PRACTICES" ;
    rdfs:subClassOf nexus:AIUC1EvidenceCategory ;
    skos:definition "Operational Practices" .

<https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#TECHNICAL_IMPLEMENTATION> a owl:Class ;
    rdfs:label "TECHNICAL_IMPLEMENTATION" ;
    rdfs:subClassOf nexus:AIUC1EvidenceCategory ;
    skos:definition "Technical Implementation" .

<https://w3id.org/ai-atlas-nexus/AIUC1EvidenceCategory#THIRD_PARTY_EVALS> a owl:Class ;
    rdfs:label "THIRD_PARTY_EVALS" ;
    rdfs:subClassOf nexus:AIUC1EvidenceCategory ;
    skos:definition "Third-party Evals" .

<https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_12> a owl:Class ;
    rdfs:label "MONTHS_12" ;
    rdfs:subClassOf nexus:AIUC1Frequency ;
    skos:definition "Every 12 months" .

<https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_3> a owl:Class ;
    rdfs:label "MONTHS_3" ;
    rdfs:subClassOf nexus:AIUC1Frequency ;
    skos:definition "Every 3 months" .

<https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_6> a owl:Class ;
    rdfs:label "MONTHS_6" ;
    rdfs:subClassOf nexus:AIUC1Frequency ;
    skos:definition "Every 6 months" .

<https://w3id.org/ai-atlas-nexus/AIUC1RequirementType#DETECTIVE> a owl:Class ;
    rdfs:label "DETECTIVE" ;
    rdfs:subClassOf nexus:AIUC1RequirementType ;
    skos:definition "Detective" .

<https://w3id.org/ai-atlas-nexus/AIUC1RequirementType#PREVENTATIVE> a owl:Class ;
    rdfs:label "PREVENTATIVE" ;
    rdfs:subClassOf nexus:AIUC1RequirementType ;
    skos:definition "Preventative" .

nexus:AIUser a owl:Class ;
    rdfs:label "AIUser" ;
    rdfs:subClassOf nexus:Stakeholder ;
    skos:definition "Individual or group that interacts with a system." ;
    skos:exactMatch airo:AIUser ;
    skos:inScheme nexus:ai_system .

<https://w3id.org/ai-atlas-nexus/AdapterType#ALORA> a owl:Class ;
    rdfs:label "ALORA" ;
    rdfs:subClassOf nexus:AdapterType ;
    skos:definition "Activated LoRA (aLoRA) is a low rank adapter architecture that allows for reusing existing base model KV cache for more efficient inference, unlike standard LoRA models. As a result, aLoRA models can be quickly invoked as-needed for specialized tasks during (long) flows where the base model is primarily used, avoiding potentially expensive prefill costs in terms of latency, throughput, and GPU memory. See arXiv:2504.12397 for further details." .

<https://w3id.org/ai-atlas-nexus/AdapterType#LORA> a owl:Class ;
    rdfs:label "LORA" ;
    rdfs:subClassOf nexus:AdapterType ;
    skos:definition "Low-rank adapters, or LoRAs, are a fast way to give generalist large language models targeted knowledge and skills so they can do things like summarize IT manuals or rate the accuracy of their own answers. LoRA reduces the number of trainable parameters by learning pairs of rank-decompostion matrices while freezing the original weights. This vastly reduces the storage requirement for large language models adapted to specific tasks and enables efficient task-switching during deployment all without introducing inference latency. LoRA also outperforms several other adaptation methods including adapter, prefix-tuning, and fine-tuning. See arXiv:2106.09685" .

<https://w3id.org/ai-atlas-nexus/AdapterType#X-LORA> a owl:Class ;
    rdfs:label "X-LORA" ;
    rdfs:subClassOf nexus:AdapterType ;
    skos:definition "Mixture of LoRA Experts (X-LoRA) is a mixture of experts method for LoRA which works by using dense or sparse gating to dynamically activate LoRA experts." .

nexus:AiAgent a owl:Class ;
    rdfs:label "AiAgent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isProvidedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isProvidedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom owl:Thing ;
            owl:onProperty nexus:isProvidedBy ],
        nexus:AiSystem ;
    skos:definition "An artificial intelligence (AI) agent refers to a system or program that is capable of autonomously performing tasks on behalf of a user or another system by designing its workflow and utilizing available tools." ;
    skos:inScheme nexus:ai_system .

nexus:AiLifecyclePhase a owl:Class ;
    rdfs:label "AiLifecyclePhase" ;
    rdfs:subClassOf nexus:Entity ;
    skos:definition "A Phase of AI lifecycle which indicates evolution of the system from conception through retirement." ;
    skos:exactMatch airo:AILifecyclePhase ;
    skos:inScheme nexus:ai_system .

<https://w3id.org/ai-atlas-nexus/AiSystemType#GPAI> a owl:Class ;
