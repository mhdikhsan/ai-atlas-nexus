        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasAdapter ],
        [ a owl:Restriction ;
