        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRule ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasException ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasException ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasReasonDenial ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasShortReplyType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasReasonDenial ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasShortReplyType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasReasonDenial ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasShortReplyType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasException ],
        nexus:Policy ;
    skos:definition "The policy guides how the language model should answer a diverse set of sensitive questions." ;
    skos:inScheme nexus:common .

nexus:LargeLanguageModelFamily a owl:Class ;
    rdfs:label "LargeLanguageModelFamily" ;
    rdfs:subClassOf [ a owl:Restriction ;
