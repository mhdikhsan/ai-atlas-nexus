<https://w3id.org/ai-atlas-nexus/AiSystemType#GPAI_OS> a owl:Class ;
    rdfs:label "GPAI_OS" ;
    rdfs:subClassOf nexus:AiSystemType ;
    skos:definition "General-purpose AI (GPAI) models released under free and open-source licences" .

<https://w3id.org/ai-atlas-nexus/AiSystemType#HIGH_RISK> a owl:Class ;
    rdfs:label "HIGH_RISK" ;
    rdfs:subClassOf nexus:AiSystemType ;
    skos:definition "AI systems pursuant to Article 6(1)(2) Classification Rules for High-Risk AI Systems" .

<https://w3id.org/ai-atlas-nexus/AiSystemType#MILITARY_SECURITY> a owl:Class ;
    rdfs:label "MILITARY_SECURITY" ;
    rdfs:subClassOf nexus:AiSystemType ;
