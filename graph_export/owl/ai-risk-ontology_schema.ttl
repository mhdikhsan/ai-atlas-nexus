nexus:LLMIntrinsic a owl:Class ;
    rdfs:label "LLMIntrinsic" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:implementsCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Adapter ;
