    rdfs:range nexus:Any ;
    skos:definition "The property is used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications" ;
    skos:inScheme nexus:common .

nexus:groups a owl:ObjectProperty ;
    rdfs:label "groups" ;
    skos:definition "A list of groups" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:hasAISubject a owl:ObjectProperty ;
    rdfs:label "hasAISubject" ;
    rdfs:range nexus:AISubject ;
    skos:definition "Indicates the subjects of an AI system" ;
    skos:inScheme nexus:ai_system .

nexus:hasAIUser a owl:ObjectProperty ;
    rdfs:label "hasAIUser" ;
    rdfs:domain nexus:AiSystem ;
    rdfs:range nexus:AIUser ;
    skos:definition "Indicate the end-user of an AI system." ;
    skos:inScheme nexus:ai_system .

nexus:hasAdapter a owl:ObjectProperty ;
    rdfs:label "hasAdapter" ;
    rdfs:domain nexus:LLMIntrinsic ;
    rdfs:range nexus:Adapter ;
    skos:definition "The Adapter for the intrinsic" ;
    skos:inScheme nexus:ai_intrinsic .

nexus:hasAdapterType a owl:ObjectProperty ;
    rdfs:label "hasAdapterType" ;
    rdfs:range nexus:AdapterType ;
    skos:definition "The Adapter type, for example: LORA, ALORA, X-LORA" ;
    skos:inScheme nexus:ai_intrinsic .

nexus:hasAiActorTask a owl:DatatypeProperty ;
    rdfs:label "hasAiActorTask" ;
    skos:definition "Pertinent AI Actor Tasks for each subcategory. Not every AI Actor Task listed will apply to every suggested action in the subcategory (i.e., some apply to AI development and others apply to AI deployment)." ;
    skos:inScheme nexus:ai_risk .

nexus:hasAnnotation a owl:DatatypeProperty ;
    rdfs:label "hasAnnotation" ;
    skos:definition "The process used to annotate or label the dataset, including who or what performed the annotations (e.g., human annotators, automated processes)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasApplication a owl:ObjectProperty ;
    rdfs:label "hasApplication" ;
    rdfs:domain nexus:Requirement ;
    rdfs:range nexus:AIUC1ApplicationCategory ;
    skos:definition "The application category, Optional or Mandatory." ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasBaselineResults a owl:DatatypeProperty ;
    rdfs:label "hasBaselineResults" ;
    skos:definition "The results of well-known or widely used models to give context to new performance scores." ;
    skos:inScheme nexus:ai_eval .

nexus:hasCalculation a owl:DatatypeProperty ;
    rdfs:label "hasCalculation" ;
    skos:definition "The way metrics are computed based on model outputs and the benchmark data." ;
    skos:inScheme nexus:ai_eval .

nexus:hasConsiderationComplianceWithRegulations a owl:DatatypeProperty ;
    rdfs:label "hasConsiderationComplianceWithRegulations" ;
    skos:definition "Compliance with relevant legal or ethical regulations (if applicable)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasConsiderationConsentProcedures a owl:DatatypeProperty ;
    rdfs:label "hasConsiderationConsentProcedures" ;
    skos:definition "Information on how consent was obtained (if applicable), especially for datasets involving personal data." ;
    skos:inScheme nexus:ai_eval .

nexus:hasConsiderationPrivacyAndAnonymity a owl:DatatypeProperty ;
    rdfs:label "hasConsiderationPrivacyAndAnonymity" ;
    skos:definition "How any personal or sensitive data is handled and whether any anonymization techniques are applied." ;
    skos:inScheme nexus:ai_eval .

nexus:hasDataset a owl:ObjectProperty ;
    rdfs:label "hasDataset" ;
    rdfs:range nexus:Dataset ;
    skos:definition "A relationship to datasets that are used." ;
    skos:inScheme nexus:common .

nexus:hasDemographicAnalysis a owl:DatatypeProperty ;
    rdfs:label "hasDemographicAnalysis" ;
    skos:definition "How the benchmark evaluates performance across different demographic groups (e.g., gender, race)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasEvaluation a owl:ObjectProperty ;
    rdfs:label "hasEvaluation" ;
    rdfs:range nexus:AiEvalResult ;
    skos:definition "A relationship indicating that an entity has an AI evaluation result." ;
    skos:inScheme nexus:ai_eval .

nexus:hasEvaluationResults a owl:ObjectProperty ;
    rdfs:label "hasEvaluationResults" ;
    rdfs:domain nexus:EveryEvalAIResult ;
    rdfs:range nexus:EvaluationResultRecord ;
    skos:definition "Array of evaluation results" ;
    skos:inScheme nexus:ai_eval .

nexus:hasEvidenceCategory a owl:ObjectProperty ;
    rdfs:label "hasEvidenceCategory" ;
    rdfs:domain nexus:ControlActivity ;
    rdfs:range nexus:AIUC1EvidenceCategory ;
    skos:definition "The evidence category, ie Technical Implementation, Operational Practices, etc." ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasImplementation a owl:DatatypeProperty ;
    rdfs:label "hasImplementation" ;
    rdfs:range xsd:anyURI ;
    skos:definition "A relationship to a implementation defining the risk evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:hasInputModality a owl:ObjectProperty ;
    rdfs:label "hasInputModality" ;
    rdfs:range nexus:Modality ;
    skos:definition "A relationship indicating the input modalities supported by an AI component. Examples include text, image, video." ;
    skos:inScheme nexus:ai_system .

nexus:hasInterpretation a owl:DatatypeProperty ;
    rdfs:label "hasInterpretation" ;
    skos:definition "How users should interpret the scores or results from the metrics." ;
    skos:inScheme nexus:ai_eval .

nexus:hasJurisdiction a owl:ObjectProperty ;
    rdfs:label "hasJurisdiction" ;
    rdfs:range nexus:Jurisdiction ;
    skos:definition "The legal or political jurisdiction(s) in which this concept applies, expressed as ISO 3166-1 country codes." ;
    skos:inScheme nexus:common .

nexus:hasKeywords a owl:DatatypeProperty ;
    rdfs:label "hasKeywords" ;
    rdfs:domain nexus:Requirement ;
    rdfs:range xsd:string ;
    skos:definition "A collection of keywords" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasModelCard a owl:DatatypeProperty ;
    rdfs:label "hasModelCard" ;
    rdfs:range xsd:string ;
    skos:definition "A relationship to model card references." ;
    skos:inScheme nexus:ai_system .

nexus:hasOutOfScopeUses a owl:DatatypeProperty ;
    rdfs:label "hasOutOfScopeUses" ;
    skos:definition "Use cases where the benchmark is not designed to be applied and could give misleading results." ;
    skos:inScheme nexus:ai_eval .

nexus:hasOutputModality a owl:ObjectProperty ;
    rdfs:label "hasOutputModality" ;
    rdfs:range nexus:Modality ;
    skos:definition "A relationship indicating the output modalities supported by an AI component. Examples include text, image, video." ;
    skos:inScheme nexus:ai_system .

nexus:hasParentDefinition a owl:ObjectProperty ;
    rdfs:label "hasParentDefinition" ;
    rdfs:range nexus:Term ;
    skos:definition "Indicates parent terms associated with a term" ;
    skos:inScheme nexus:common .

nexus:hasPrinciple a owl:ObjectProperty ;
    rdfs:label "hasPrinciple" ;
    rdfs:domain nexus:Requirement ;
    rdfs:range nexus:Principle ;
    skos:definition "Which of the AIUC-1 principles this requirement belongs to" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasPurpose a owl:ObjectProperty ;
    rdfs:label "hasPurpose" ;
    rdfs:range nexus:Purpose ;
    skos:definition "Indicates the purpose of an entity, e.g. AI system, components." ;
    skos:inScheme nexus:ai_system .

nexus:hasRelatedAction a owl:ObjectProperty ;
    rdfs:label "hasRelatedAction" ;
    rdfs:range nexus:Action ;
    skos:definition "A relationship where an entity relates to an action" ;
    skos:inScheme nexus:ai_risk .

nexus:hasRelatedTerm a owl:ObjectProperty ;
    rdfs:label "hasRelatedTerm" ;
    rdfs:domain nexus:Any ;
    rdfs:range [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Term ) ] ;
    skos:definition "A relationship where an entity relates to a term" ;
    skos:inScheme nexus:common .

nexus:hasRiskControl a owl:ObjectProperty ;
    rdfs:label "hasRiskControl" ;
    rdfs:range nexus:RiskControl ;
    skos:definition "Indicates the control measures associated with a system or component to modify risks." ;
    skos:inScheme nexus:ai_system .

nexus:hasSimilarBenchmarks a owl:DatatypeProperty ;
    rdfs:label "hasSimilarBenchmarks" ;
    skos:definition "Benchmarks that are closely related in terms of goals or data type." ;
    skos:inScheme nexus:ai_eval .

nexus:hasSubDefinition a owl:ObjectProperty ;
    rdfs:label "hasSubDefinition" ;
    rdfs:range nexus:Term ;
    skos:definition "Indicates child terms associated with a term" ;
    skos:inScheme nexus:common .

nexus:hasTrainingData a owl:ObjectProperty ;
    rdfs:label "hasTrainingData" ;
    rdfs:range nexus:Dataset ;
    skos:definition "A relationship indicating the datasets an AI model was trained on." ;
    skos:inScheme nexus:ai_system .

nexus:hasTypicalLocation a owl:DatatypeProperty ;
    rdfs:label "hasTypicalLocation" ;
    rdfs:domain nexus:ControlActivity ;
    rdfs:range xsd:string ;
    skos:definition "The evidence is usually found here" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasUnitxtCard a owl:DatatypeProperty ;
    rdfs:label "hasUnitxtCard" ;
    rdfs:range xsd:anyURI ;
    skos:definition "A relationship to a Unitxt card defining the risk evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:hasValidation a owl:DatatypeProperty ;
    rdfs:label "hasValidation" ;
    skos:definition "Measures taken to ensure that the benchmark provides valid and reliable evaluations." ;
    skos:inScheme nexus:ai_eval .

nexus:isAppliedWithinDomain a owl:ObjectProperty ;
    rdfs:label "isAppliedWithinDomain" ;
    rdfs:range nexus:Domain ;
    skos:definition "Specifies the domain an AI system is used within." ;
    skos:inScheme nexus:ai_system .

nexus:isCategorizedAs a owl:ObjectProperty ;
    rdfs:label "isCategorizedAs" ;
    rdfs:range nexus:Any ;
    skos:definition "A relationship where an entity has been deemed to be categorized" ;
    skos:inScheme nexus:common .

nexus:licenses a owl:ObjectProperty ;
    rdfs:label "licenses" ;
    skos:definition "A list of licenses" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:llmintrinsics a owl:ObjectProperty ;
    rdfs:label "llmintrinsics" ;
    skos:definition "A list of LLMIntrinsics" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:modalities a owl:ObjectProperty ;
    rdfs:label "modalities" ;
    skos:definition "A list of AI modalities" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:narrow_mappings a owl:ObjectProperty ;
    rdfs:label "narrow_mappings" ;
    rdfs:range nexus:Any ;
    skos:definition "The property is used to state a hierarchical mapping link between two concepts, indicating that the concept linked to, is a narrower concept than the originating concept." ;
    skos:inScheme nexus:common .

nexus:narrower a owl:DatatypeProperty ;
    rdfs:label "narrower" ;
    skos:inScheme nexus:common .

nexus:obligations a owl:ObjectProperty ;
    rdfs:label "obligations" ;
    skos:definition "A list of Obligations" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:organizations a owl:ObjectProperty ;
    rdfs:label "organizations" ;
    skos:definition "A list of organizations" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:performsTask a owl:ObjectProperty ;
    rdfs:label "performsTask" ;
    rdfs:range nexus:AiTask ;
    skos:definition "relationship indicating the AI tasks an AI model can perform." ;
    skos:inScheme nexus:ai_system .

nexus:permissions a owl:ObjectProperty ;
    rdfs:label "permissions" ;
    skos:definition "A list of Permissions" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:policies a owl:ObjectProperty ;
    rdfs:label "policies" ;
    skos:definition "A list of policies" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:prohibitions a owl:ObjectProperty ;
    rdfs:label "prohibitions" ;
    skos:definition "A list of prohibitions" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:refersToRisk a owl:ObjectProperty ;
    rdfs:label "refersToRisk" ;
    rdfs:domain nexus:RiskIncident ;
    rdfs:range nexus:Risk ;
    skos:definition "Indicates the incident (subject) is a materialisation of the indicated risk (object)" ;
    skos:exactMatch <https://w3id.org/dpv#refersToRisk> ;
    skos:inScheme nexus:ai_risk .

nexus:related_mappings a owl:ObjectProperty ;
    rdfs:label "related_mappings" ;
    rdfs:range nexus:Any ;
    skos:definition "The property skos:relatedMatch is used to state an associative mapping link between two concepts." ;
    skos:inScheme nexus:common .

nexus:riskincidents a owl:ObjectProperty ;
    rdfs:label "riskincidents" ;
    skos:definition "A list of AI risk incidents" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:rules a owl:ObjectProperty ;
    rdfs:label "rules" ;
    skos:definition "A list of rules" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:slot_conditions a owl:ObjectProperty ;
    rdfs:label "slot_conditions" ;
    skos:inScheme nexus:common .

nexus:stakeholdergroups a owl:ObjectProperty ;
    rdfs:label "stakeholdergroups" ;
    skos:definition "A list of AI stakeholder groups" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:stakeholders a owl:ObjectProperty ;
    rdfs:label "stakeholders" ;
    skos:definition "A list of stakeholders" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:supported_languages a owl:DatatypeProperty ;
    rdfs:label "supported_languages" ;
    rdfs:range xsd:string ;
    skos:definition "A list of languages, expressed as ISO two letter codes. For example, 'jp, fr, en, de'" ;
    skos:inScheme nexus:ai_system .

nexus:taxonomies a owl:ObjectProperty ;
    rdfs:label "taxonomies" ;
    skos:definition "A list of taxonomies" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:vocabularies a owl:ObjectProperty ;
    rdfs:label "vocabularies" ;
    skos:definition "A list of vocabularies" ;
    skos:inScheme nexus:ai-risk-ontology .

nexus:AiProvider a owl:Class ;
    rdfs:label "AiProvider" ;
    rdfs:subClassOf nexus:Organization ;
    skos:definition "A provider under the AI Act is defined by Article 3(3) as a natural or legal person or body that develops an AI system or general-purpose AI model or has an AI system or general-purpose AI model developed; and places that ystem or model on the market, or puts that system into service, under the provider's own name or trademark, whether for payment or free for charge." ;
    skos:exactMatch airo:AIProvider ;
    skos:inScheme nexus:ai_system .

nexus:ControlActivityObligation a owl:Class ;
    rdfs:label "ControlActivityObligation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        nexus:ControlActivity,
        nexus:Obligation ;
    skos:definition "A control activity (rule) describing an obligation for performing an activity" ;
    skos:exactMatch nexus:ControlActivityObligation ;
    skos:inScheme nexus:ai_aiuc .

nexus:ControlActivityPermission a owl:Class ;
    rdfs:label "ControlActivityPermission" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        nexus:ControlActivity,
        nexus:Permission ;
    skos:definition "A control activity (rule) describing a permission to perform an activity" ;
    skos:exactMatch nexus:ControlActivityPermission ;
    skos:inScheme nexus:ai_aiuc .

nexus:ControlActivityProhibition a owl:Class ;
    rdfs:label "ControlActivityProhibition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        nexus:ControlActivity,
        nexus:Prohibition ;
    skos:definition "A control activity (rule) describing a prohibition to perform an activity" ;
    skos:exactMatch nexus:ControlActivityProhibition ;
    skos:inScheme nexus:ai_aiuc .

nexus:ControlActivityRecommendation a owl:Class ;
    rdfs:label "ControlActivityRecommendation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        nexus:ControlActivity,
        nexus:Recommendation ;
    skos:definition "A control activity (rule) describing a recommendation for performing an activity" ;
    skos:exactMatch nexus:ControlActivityRecommendation ;
    skos:inScheme nexus:ai_aiuc .

nexus:EveryEvalAIResult a owl:Class ;
    rdfs:label "EveryEvalAIResult" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasLanguages ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasDataType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasModelInfo ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasMetrics ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasAudience ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasMetrics ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasResources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLanguages ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasMethods ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLimitations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasDomains ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDataSource ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasGoal ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:retrieved_timestamp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:schema_version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasGoal ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:schema_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:evaluation_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasGoal ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:evaluation_timestamp ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:ModelInfo ;
            owl:onProperty nexus:hasModelInfo ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasSourceMetadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty nexus:evaluation_timestamp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasDataSize ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:retrieved_timestamp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasDataSize ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:SourceMetadata ;
            owl:onProperty nexus:hasSourceMetadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:schema_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasSourceMetadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasLimitations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDataFormat ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasTasks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasMethods ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:evaluation_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasResources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:evaluation_timestamp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDataType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasTasks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:retrieved_timestamp ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasEvaluationResults ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasAudience ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDataSize ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:evaluation_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasModelInfo ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:EvaluationResultRecord ;
            owl:onProperty nexus:hasEvaluationResults ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasDataFormat ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDomains ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasDataSource ],
        nexus:AiEvalResult ;
    skos:definition "An evaluation result from the Every Eval Ever dataset, capturing evaluation metadata and results from the EEE_datastore." ;
    skos:exactMatch nexus:everyevalairesult ;
    skos:inScheme nexus:ai_eval .

nexus:Recommendation a owl:Class ;
    rdfs:label "Recommendation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        nexus:Rule ;
    skos:definition "A rule describing a recommendation for performing an activity" ;
    skos:exactMatch <https://w3id.org/dpv#Recommendation> ;
    skos:inScheme nexus:common .

nexus:RiskGroup a owl:Class ;
    rdfs:label "RiskGroup" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Risk ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        nexus:Group,
        nexus:RiskConcept ;
    skos:definition "A group of AI system related risks that are part of a risk taxonomy." ;
    skos:inScheme nexus:ai_risk .

nexus:architecture a owl:DatatypeProperty ;
    rdfs:label "architecture" ;
    rdfs:range xsd:string ;
    skos:definition "A description of the architecture of an AI such as 'Decoder-only'." ;
    skos:inScheme nexus:ai_system .

nexus:bestValue a owl:DatatypeProperty ;
    rdfs:label "bestValue" ;
    skos:definition "Annotation of the best possible result of the evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:carbon_emitted a owl:DatatypeProperty ;
    rdfs:label "carbon_emitted" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "The number of tons of carbon dioxide equivalent that are emitted during training" ;
    skos:inScheme nexus:energy .

nexus:concern a owl:DatatypeProperty ;
    rdfs:label "concern" ;
    skos:definition "Some explanation about the concern related to an AI risk" ;
    skos:inScheme nexus:ai_risk .

nexus:contextWindowSize a owl:DatatypeProperty ;
    rdfs:label "contextWindowSize" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "The total length, in bytes, of an AI model's context window." ;
    skos:inScheme nexus:ai_system .

nexus:dataset_name a owl:DatatypeProperty ;
    rdfs:label "dataset_name" ;
    skos:definition "Name of the dataset" ;
    skos:inScheme nexus:ai_eval .

nexus:dateCreated a owl:DatatypeProperty ;
    rdfs:label "dateCreated" ;
    rdfs:range xsd:date ;
    skos:definition "The date on which the entity was created." ;
    skos:inScheme nexus:common .

nexus:dateModified a owl:DatatypeProperty ;
    rdfs:label "dateModified" ;
    rdfs:range xsd:date ;
    skos:definition "The date on which the entity was most recently modified." ;
    skos:inScheme nexus:common .

nexus:describesAiEval a owl:ObjectProperty ;
    rdfs:label "describesAiEval" ;
    rdfs:domain nexus:BenchmarkMetadataCard ;
    rdfs:range nexus:AiEval ;
    owl:inverseOf nexus:hasBenchmarkMetadata ;
    skos:definition "A relationship where a BenchmarkMetadataCard describes an AI evaluation (benchmark)." ;
    skos:inScheme nexus:ai_eval .

nexus:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    skos:definition "The description of an entity" ;
    skos:inScheme nexus:common .

nexus:equals_string a owl:DatatypeProperty ;
    rdfs:label "equals_string" ;
    skos:inScheme nexus:common .

nexus:evaluation_id a owl:DatatypeProperty ;
    rdfs:label "evaluation_id" ;
    skos:definition "Unique identifier for this evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:evaluation_name a owl:DatatypeProperty ;
    rdfs:label "evaluation_name" ;
    skos:definition "Name of the evaluation benchmark" ;
    skos:inScheme nexus:ai_eval .

nexus:evaluation_timestamp a owl:DatatypeProperty ;
    rdfs:label "evaluation_timestamp" ;
    skos:definition "ISO 8601 timestamp when evaluation was performed" ;
    skos:inScheme nexus:ai_eval .

nexus:evaluator_relationship a owl:DatatypeProperty ;
    rdfs:label "evaluator_relationship" ;
    skos:definition "Relationship of evaluator (e.g., first_party, third_party)" ;
    skos:inScheme nexus:ai_eval .

nexus:evidence a owl:DatatypeProperty ;
    rdfs:label "evidence" ;
    skos:definition "Evidence provides a source (typical a chunk, paragraph or link) describing where some value was found or how it was generated." ;
    skos:inScheme nexus:common .

nexus:fine_tuning a owl:DatatypeProperty ;
    rdfs:label "fine_tuning" ;
    rdfs:range xsd:string ;
    skos:definition "A description of the fine-tuning mechanism(s) applied to a model." ;
    skos:inScheme nexus:ai_system .

nexus:gpu_hours a owl:DatatypeProperty ;
    rdfs:label "gpu_hours" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "GPU consumption in terms of hours" ;
    skos:inScheme nexus:energy .

nexus:grants_license a owl:ObjectProperty ;
    rdfs:label "grants_license" ;
    rdfs:range nexus:License ;
    skos:definition "A relationship from a granting entity such as an Organization to a License instance." ;
    skos:inScheme nexus:common .

nexus:hasBenchmarkMetadata a owl:ObjectProperty ;
    rdfs:label "hasBenchmarkMetadata" ;
    rdfs:domain nexus:AiEval ;
    rdfs:range nexus:BenchmarkMetadataCard ;
    owl:inverseOf nexus:describesAiEval ;
    skos:definition "A relationship to a Benchmark Metadata Card which contains metadata about the benchmark." ;
    skos:inScheme nexus:ai_eval .

nexus:hasConsequence a owl:ObjectProperty ;
    rdfs:label "hasConsequence" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:Consequence ;
    skos:definition "Indicates consequence(s) possible or arising from specified concept" ;
    skos:inScheme nexus:ai_risk .

nexus:hasControlApplication a owl:ObjectProperty ;
    rdfs:label "hasControlApplication" ;
    rdfs:domain nexus:ControlActivity ;
    rdfs:range nexus:AIUC1ControlApplicationCategory ;
    skos:definition "Which of the AIUC-1 ControlApplicationCategory this control activity (rule) belongs to" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasEuAiSystemType a owl:ObjectProperty ;
    rdfs:label "hasEuAiSystemType" ;
    rdfs:range nexus:AiSystemType ;
    skos:definition "The type of system as defined by the EU AI Act." ;
    skos:inScheme nexus:eu_ai_act .

nexus:hasEuRiskCategory a owl:ObjectProperty ;
    rdfs:label "hasEuRiskCategory" ;
    rdfs:range nexus:EuAiRiskCategory ;
    skos:definition "The risk category of an AI system as defined by the EU AI Act." ;
    skos:inScheme nexus:eu_ai_act .

nexus:hasException a owl:DatatypeProperty ;
    rdfs:label "hasException" ;
    rdfs:range xsd:string ;
    skos:definition "Exception type" ;
    skos:inScheme nexus:common .

nexus:hasFrequency a owl:ObjectProperty ;
    rdfs:label "hasFrequency" ;
    rdfs:domain nexus:Requirement ;
    rdfs:range nexus:AIUC1Frequency ;
    skos:definition "The frequency" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasImpact a owl:ObjectProperty ;
    rdfs:label "hasImpact" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:Impact ;
    skos:broadMatch <https://w3id.org/dpv#hasConsequence> ;
    skos:definition "Indicates impact(s) possible or arising as consequences from specified concept" ;
    skos:inScheme nexus:ai_risk .

nexus:hasImpactOn a owl:ObjectProperty ;
    rdfs:label "hasImpactOn" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:Impact ;
    skos:broadMatch <https://w3id.org/dpv#hasConsequenceOn> ;
    skos:definition "Indicates impact(s) possible or arising as consequences from specified concept" ;
    skos:inScheme nexus:ai_risk .

nexus:hasLikelihood a owl:ObjectProperty ;
    rdfs:label "hasLikelihood" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:Likelihood ;
    skos:definition "The likelihood or probability or chance of something taking place or occuring" ;
    skos:inScheme nexus:ai_risk .

nexus:hasMetricConfig a owl:ObjectProperty ;
    rdfs:label "hasMetricConfig" ;
    rdfs:domain nexus:EvaluationResultRecord ;
    rdfs:range nexus:MetricConfig ;
    skos:definition "Metric configuration" ;
    skos:inScheme nexus:ai_eval .

nexus:hasModelInfo a owl:ObjectProperty ;
    rdfs:label "hasModelInfo" ;
    rdfs:domain nexus:EveryEvalAIResult ;
    rdfs:range nexus:ModelInfo ;
    skos:definition "Model information for the evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:hasReasonDenial a owl:DatatypeProperty ;
    rdfs:label "hasReasonDenial" ;
    rdfs:range xsd:string ;
    skos:definition "Reason for denial" ;
    skos:inScheme nexus:common .

nexus:hasRequirement a owl:ObjectProperty ;
    rdfs:label "hasRequirement" ;
    rdfs:domain nexus:ControlActivity ;
    rdfs:range nexus:Requirement ;
    skos:definition "This requirement this rule belongs to" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasScoreDetails a owl:ObjectProperty ;
    rdfs:label "hasScoreDetails" ;
    rdfs:domain nexus:EvaluationResultRecord ;
    rdfs:range nexus:ScoreDetails ;
    skos:definition "Score details" ;
    skos:inScheme nexus:ai_eval .

nexus:hasSeverity a owl:ObjectProperty ;
    rdfs:label "hasSeverity" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:Severity ;
    skos:definition "Indicates the severity associated with a concept" ;
    skos:inScheme nexus:ai_risk .

nexus:hasShortReplyType a owl:DatatypeProperty ;
    rdfs:label "hasShortReplyType" ;
    rdfs:range xsd:string ;
    skos:definition "Short reply type" ;
    skos:inScheme nexus:common .

nexus:hasSourceData a owl:ObjectProperty ;
    rdfs:label "hasSourceData" ;
    rdfs:domain nexus:EvaluationResultRecord ;
    rdfs:range nexus:SourceData ;
    skos:definition "Source data information" ;
    skos:inScheme nexus:ai_eval .

nexus:hasSourceMetadata a owl:ObjectProperty ;
    rdfs:label "hasSourceMetadata" ;
    rdfs:domain nexus:EveryEvalAIResult ;
    rdfs:range nexus:SourceMetadata ;
    skos:definition "Source metadata for the evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:hasStakeholder a owl:ObjectProperty ;
    rdfs:label "hasStakeholder" ;
    rdfs:range nexus:Stakeholder ;
    skos:definition "Indicates stakeholders of an AI system or component." ;
    skos:inScheme nexus:ai_system .

nexus:hasStatus a owl:ObjectProperty ;
    rdfs:label "hasStatus" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:IncidentStatus ;
    skos:definition "Indicates the status of specified concept" ;
    skos:inScheme nexus:ai_risk .

nexus:hasTypicalEvidence a owl:DatatypeProperty ;
    rdfs:label "hasTypicalEvidence" ;
    rdfs:domain nexus:ControlActivity ;
    rdfs:range xsd:string ;
    skos:definition "The evidence is usually found here" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasVariant a owl:ObjectProperty ;
    rdfs:label "hasVariant" ;
    rdfs:domain nexus:RiskIncident ;
    rdfs:range nexus:RiskIncident ;
    skos:definition "Indicates an incident that shares the same causative factors, produces similar harms, and involves the same intelligent systems as a known AI incident." ;
    skos:inScheme nexus:ai_risk .

nexus:hf_repo a owl:DatatypeProperty ;
    rdfs:label "hf_repo" ;
    skos:definition "HuggingFace repository" ;
    skos:inScheme nexus:ai_eval .

nexus:hf_split a owl:DatatypeProperty ;
    rdfs:label "hf_split" ;
    skos:definition "HuggingFace dataset split" ;
    skos:inScheme nexus:ai_eval .

nexus:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    skos:definition "A unique identifier to this instance of the model element. Example identifiers include UUID, URI, URN, etc." ;
    skos:inScheme nexus:common .

nexus:isDeployedBy a owl:ObjectProperty ;
    rdfs:label "isDeployedBy" ;
    rdfs:range nexus:AIDeployer ;
    skos:definition "Indicates the deployer of an AI system or component." ;
    skos:inScheme nexus:ai_system .

nexus:isDetectedBy a owl:ObjectProperty ;
    rdfs:label "isDetectedBy" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:RiskControl ;
    owl:inverseOf nexus:detectsRiskConcept ;
    skos:definition "A relationship where a risk, risk source, consequence, or impact is detected by a risk control." ;
    skos:inScheme nexus:ai_risk .

nexus:isDevelopedBy a owl:ObjectProperty ;
    rdfs:label "isDevelopedBy" ;
    rdfs:range nexus:AIDeveloper ;
    skos:definition "Indicates the developer of an AI system or component." ;
    skos:inScheme nexus:ai_system .

nexus:isMitigatedBy a owl:ObjectProperty ;
    rdfs:label "isMitigatedBy" ;
    rdfs:domain nexus:RiskConcept ;
    rdfs:range nexus:RiskControl ;
    owl:inverseOf nexus:mitigatesRiskConcept ;
    skos:definition "A relationship where a risk, risk source, consequence, or impact is mitigated by a risk control." ;
    skos:inScheme nexus:ai_risk .

nexus:isResultOf a owl:ObjectProperty ;
    rdfs:label "isResultOf" ;
    rdfs:range nexus:AiEval ;
    skos:definition "A relationship indicating that an entity is the result of an AI evaluation." ;
    skos:inScheme nexus:ai_eval .

nexus:lower_is_better a owl:DatatypeProperty ;
    rdfs:label "lower_is_better" ;
    skos:definition "Whether lower scores are better" ;
    skos:inScheme nexus:ai_eval .

nexus:max_score a owl:DatatypeProperty ;
    rdfs:label "max_score" ;
    skos:definition "Maximum possible score" ;
    skos:inScheme nexus:ai_eval .

nexus:min_score a owl:DatatypeProperty ;
    rdfs:label "min_score" ;
    skos:definition "Minimum possible score" ;
    skos:inScheme nexus:ai_eval .

nexus:mitigatesRiskConcept a owl:ObjectProperty ;
    rdfs:label "mitigatesRiskConcept" ;
    rdfs:domain nexus:RiskControl ;
    rdfs:range nexus:RiskConcept ;
    owl:inverseOf nexus:isMitigatedBy ;
    skos:definition "Indicates the control used for mitigating risks, risk sources, consequences, and impacts." ;
    skos:exactMatch airo:mitigatesRiskConcept ;
    skos:inScheme nexus:ai_risk .

nexus:model_id a owl:DatatypeProperty ;
    rdfs:label "model_id" ;
    skos:definition "Identifier of the AI model" ;
    skos:inScheme nexus:ai_eval .

nexus:model_name a owl:DatatypeProperty ;
    rdfs:label "model_name" ;
    skos:definition "Name of the AI model" ;
    skos:inScheme nexus:ai_eval .

nexus:numParameters a owl:DatatypeProperty ;
    rdfs:label "numParameters" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "A property indicating the number of parameters in a LLM." ;
    skos:inScheme nexus:ai_system .

nexus:numTrainingTokens a owl:DatatypeProperty ;
    rdfs:label "numTrainingTokens" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "The number of tokens a AI model was trained on." ;
    skos:inScheme nexus:ai_system .

nexus:overview a owl:DatatypeProperty ;
    rdfs:label "overview" ;
    skos:definition "A brief description of the benchmark's main goals and scope." ;
    skos:inScheme nexus:ai_eval .

nexus:phase a owl:DatatypeProperty ;
    rdfs:label "phase" ;
    skos:definition "Annotation whether an AI risk shows specifically during the training-tuning or inference phase." ;
    skos:inScheme nexus:ai_risk .

nexus:postconditions a owl:ObjectProperty ;
    rdfs:label "postconditions" ;
    skos:inScheme nexus:common .

nexus:power_consumption_w a owl:DatatypeProperty ;
    rdfs:label "power_consumption_w" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "power consumption in Watts" ;
    skos:inScheme nexus:energy .

nexus:preconditions a owl:ObjectProperty ;
    rdfs:label "preconditions" ;
    skos:inScheme nexus:common .

nexus:producer a owl:ObjectProperty ;
    rdfs:label "producer" ;
    rdfs:range nexus:Organization ;
    skos:definition "A relationship to the Organization instance which produces this instance." ;
    skos:inScheme nexus:common .

nexus:provider a owl:ObjectProperty ;
    rdfs:label "provider" ;
    rdfs:range nexus:Organization ;
    skos:definition "A relationship to the Organization instance that provides this instance." ;
    skos:inScheme nexus:common .

nexus:retrieved_timestamp a owl:DatatypeProperty ;
    rdfs:label "retrieved_timestamp" ;
    skos:definition "Unix timestamp when the data was retrieved" ;
    skos:inScheme nexus:ai_eval .

nexus:risk_type a owl:DatatypeProperty ;
    rdfs:label "risk_type" ;
    skos:definition "Annotation whether an AI risk occurs at input or output or is non-technical." ;
    skos:inScheme nexus:ai_risk .

nexus:schema_version a owl:DatatypeProperty ;
    rdfs:label "schema_version" ;
    skos:definition "Version of the evaluation schema" ;
    skos:inScheme nexus:ai_eval .

nexus:score a owl:DatatypeProperty ;
    rdfs:label "score" ;
    skos:definition "The evaluation score" ;
    skos:inScheme nexus:ai_eval .

nexus:score_type a owl:DatatypeProperty ;
    rdfs:label "score_type" ;
    skos:definition "Type of score (e.g., continuous)" ;
    skos:inScheme nexus:ai_eval .

nexus:slot_name a owl:DatatypeProperty ;
    rdfs:label "slot_name" ;
    skos:inScheme nexus:common .

nexus:source_name a owl:DatatypeProperty ;
    rdfs:label "source_name" ;
    skos:definition "Name of the evaluation source" ;
    skos:inScheme nexus:ai_eval .

nexus:source_organization_name a owl:DatatypeProperty ;
    rdfs:label "source_organization_name" ;
    skos:definition "Organization that provided the evaluation" ;
    skos:inScheme nexus:ai_eval .

nexus:source_organization_url a owl:DatatypeProperty ;
    rdfs:label "source_organization_url" ;
    skos:definition "URL of the source organization" ;
    skos:inScheme nexus:ai_eval .

nexus:source_uri a owl:DatatypeProperty ;
    rdfs:label "source_uri" ;
    skos:definition "The uri of the incident" ;
    skos:inScheme nexus:ai_risk .

nexus:tag a owl:DatatypeProperty ;
    rdfs:label "tag" ;
    skos:definition "A shost version of the name" ;
    skos:inScheme nexus:ai_risk .

nexus:text a owl:DatatypeProperty ;
    rdfs:label "text" ;
    skos:definition "The question itself" ;
    skos:inScheme nexus:ai_eval .

nexus:url a owl:DatatypeProperty ;
    rdfs:label "url" ;
    rdfs:range xsd:anyURI ;
    skos:definition "An optional URL associated with this instance." ;
    skos:inScheme nexus:common .

nexus:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    skos:definition "Some numeric or string value" ;
    skos:inScheme nexus:common .

nexus:AIUC1ApplicationCategory a owl:Class ;
    rdfs:label "AIUC1ApplicationCategory" ;
    owl:unionOf ( <https://w3id.org/ai-atlas-nexus/AIUC1ApplicationCategory#MANDATORY> <https://w3id.org/ai-atlas-nexus/AIUC1ApplicationCategory#OPTIONAL> ) ;
    skos:inScheme nexus:ai_aiuc ;
    linkml:permissible_values <https://w3id.org/ai-atlas-nexus/AIUC1ApplicationCategory#MANDATORY>,
        <https://w3id.org/ai-atlas-nexus/AIUC1ApplicationCategory#OPTIONAL> .

nexus:AIUC1ControlApplicationCategory a owl:Class ;
    rdfs:label "AIUC1ControlApplicationCategory" ;
    owl:unionOf ( <https://w3id.org/ai-atlas-nexus/AIUC1ControlApplicationCategory#CORE> <https://w3id.org/ai-atlas-nexus/AIUC1ControlApplicationCategory#SUPPLEMENTAL> ) ;
    skos:inScheme nexus:ai_aiuc ;
    linkml:permissible_values <https://w3id.org/ai-atlas-nexus/AIUC1ControlApplicationCategory#CORE>,
        <https://w3id.org/ai-atlas-nexus/AIUC1ControlApplicationCategory#SUPPLEMENTAL> .

nexus:AiEvalResult a owl:Class ;
    rdfs:label "AiEvalResult" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isResultOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiEval ;
            owl:onProperty nexus:isResultOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isResultOf ],
        nexus:Entity,
        nexus:Fact ;
    skos:definition "The result of an evaluation for a specific AI model." ;
    skos:exactMatch <https://www.w3.org/TR/vocab-dqv/QualityMeasurement> ;
    skos:inScheme nexus:ai_eval .

nexus:AiSystem a owl:Class ;
    rdfs:label "AiSystem" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isComposedOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiSystemType ;
            owl:onProperty nexus:hasEuAiSystemType ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AIDeployer ;
            owl:onProperty nexus:isDeployedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasStakeholder ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Domain ;
            owl:onProperty nexus:isAppliedWithinDomain ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AIDeveloper ;
            owl:onProperty nexus:isDevelopedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasEuAiSystemType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasEuRiskCategory ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasAISubject ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AISubject ;
            owl:onProperty nexus:hasAISubject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasStakeholder ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Purpose ;
            owl:onProperty nexus:hasPurpose ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasPurpose ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AIUser ;
            owl:onProperty nexus:hasAIUser ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasAIUser ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:EuAiRiskCategory ;
            owl:onProperty nexus:hasEuRiskCategory ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasEuRiskCategory ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDeployedBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDevelopedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LocalityOfUse ;
            owl:onProperty nexus:isUsedWithinLocality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDeployedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDevelopedBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasEuAiSystemType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isAppliedWithinDomain ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:hasCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Stakeholder ;
            owl:onProperty nexus:hasStakeholder ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:BaseAi ;
            owl:onProperty nexus:isComposedOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isUsedWithinLocality ],
        nexus:BaseAi,
        nexus:Entry ;
    skos:definition "A compound AI System composed of one or more AI capablities. ChatGPT is an example of an AI system which deploys multiple GPT AI models." ;
    skos:exactMatch airo:AISystem ;
    skos:inScheme nexus:ai_system .

nexus:AiTaskDomain a owl:Class ;
    rdfs:label "AiTaskDomain" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiTaskGroup ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        nexus:Group ;
    skos:definition "A grouping of AI Tasks by domain." ;
    skos:exactMatch nexus:AiTaskDomain ;
    skos:inScheme nexus:ai_system .

nexus:AiTaskGroup a owl:Class ;
    rdfs:label "AiTaskGroup" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiTask ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiTaskDomain ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isPartOf ],
        nexus:Group ;
    skos:definition "A group of AI Tasks." ;
    skos:exactMatch nexus:AiTaskGroup ;
    skos:inScheme nexus:ai_system .

nexus:BaseAi a owl:Class ;
    rdfs:label "BaseAi" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:performsTask ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:producer ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiProvider ;
            owl:onProperty nexus:isProvidedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isProvidedBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiTask ;
            owl:onProperty nexus:performsTask ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasModelCard ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasModelCard ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isProvidedBy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:producer ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:License ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Organization ;
            owl:onProperty nexus:producer ],
        nexus:Entity ;
    skos:definition "Any type of AI, be it a LLM, RL agent, SVM, etc." ;
    skos:inScheme nexus:ai_system .

nexus:CapabilityGroup a owl:Class ;
    rdfs:label "CapabilityGroup" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:belongsToDomain ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:belongsToDomain ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:CapabilityDomain ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:CapabilityDomain ;
            owl:onProperty nexus:belongsToDomain ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        nexus:CapabilityConcept,
        nexus:Group ;
    skos:definition "A group of AI capabilities that are part of a capability taxonomy, organized under a domain" ;
    skos:inScheme nexus:ai_capability .

nexus:Domain a owl:Class ;
    rdfs:label "Domain" ;
    rdfs:subClassOf nexus:Entry ;
    skos:definition "An area, sector, or industry that is associated with economic activities." ;
    skos:exactMatch airo:Domain ;
    skos:inScheme nexus:ai_system .

nexus:LargeLanguageModel a owl:Class ;
    rdfs:label "LargeLanguageModel" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:fine_tuning ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty nexus:numParameters ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:numParameters ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:numTrainingTokens ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:contextWindowSize ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:numParameters ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Modality ;
            owl:onProperty nexus:hasInputModality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:requiresCapability ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LargeLanguageModelFamily ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty nexus:numTrainingTokens ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:contextWindowSize ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:supported_languages ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Modality ;
            owl:onProperty nexus:hasOutputModality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasInputModality ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:requiresCapability ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasOutputModality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasTrainingData ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:supported_languages ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Dataset ;
            owl:onProperty nexus:hasTrainingData ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:fine_tuning ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:fine_tuning ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
            owl:onProperty nexus:contextWindowSize ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:numTrainingTokens ],
        nexus:AiModel ;
    skos:altLabel "LLM" ;
    skos:definition "A large language model (LLM) is an AI model which supports a range of language-related tasks such as generation, summarization, classification, among others. A LLM is implemented as an artificial neural networks using a transformer architecture." ;
    skos:inScheme nexus:ai_system .

nexus:Obligation a owl:Class ;
    rdfs:label "Obligation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        nexus:Rule ;
    skos:definition "A rule describing an obligation for performing an activity" ;
    skos:exactMatch <https://w3id.org/dpv#Obligation> ;
    skos:inScheme nexus:common .

nexus:Permission a owl:Class ;
    rdfs:label "Permission" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        nexus:Rule ;
    skos:definition "A rule describing a permission to perform an activity" ;
    skos:exactMatch <https://w3id.org/dpv#Permission> ;
    skos:inScheme nexus:common .

nexus:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:LocalityOfUse ;
            owl:onProperty nexus:isApplicableinLocality ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isApplicableinLocality ],
        nexus:Entity ;
    skos:definition "A guidance document outlining any of: procedures, plans, principles, decisions, intent, or protocols." ;
    skos:exactMatch <https://w3id.org/dpv#Policy> ;
    skos:inScheme nexus:common .

nexus:Principle a owl:Class ;
    rdfs:label "Principle" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        nexus:Entry ;
    skos:definition "A representation of values or norms that must be taken into consideration when conducting activities." ;
    skos:exactMatch <https://w3id.org/dpv#Principle> ;
    skos:inScheme nexus:common .

nexus:Prohibition a owl:Class ;
    rdfs:label "Prohibition" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        nexus:Rule ;
    skos:definition "A rule describing a prohibition to perform an activity" ;
    skos:exactMatch <https://w3id.org/dpv#Prohibition> ;
    skos:inScheme nexus:common .

nexus:Purpose a owl:Class ;
    rdfs:label "Purpose" ;
    rdfs:subClassOf nexus:Entry ;
    skos:definition "The end goal for which an entity is used or an action is taken." ;
    skos:exactMatch airo:Purpose ;
    skos:inScheme nexus:ai_system .

nexus:StakeholderGroup a owl:Class ;
    rdfs:label "StakeholderGroup" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        nexus:Group ;
    skos:definition "An AI system stakeholder grouping." ;
    skos:inScheme nexus:ai_system .

nexus:appliesToCapability a owl:ObjectProperty ;
    rdfs:label "appliesToCapability" ;
    rdfs:domain nexus:ControlActivity ;
    rdfs:range nexus:AiTask ;
    skos:definition "This evidence only applies to AI systems with this capability" ;
    skos:inScheme nexus:ai_aiuc .

nexus:hasAudience a owl:DatatypeProperty ;
    rdfs:label "hasAudience" ;
    skos:definition "The intended audience, such as researchers, developers, policymakers, etc." ;
    skos:inScheme nexus:ai_eval .

nexus:hasDataFormat a owl:DatatypeProperty ;
    rdfs:label "hasDataFormat" ;
    skos:definition "The structure and modality of the data (e.g., sentence pairs, question-answer format, tabular data)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasDataSource a owl:DatatypeProperty ;
    rdfs:label "hasDataSource" ;
    skos:definition "The origin or source of the data used in the benchmark (e.g., curated datasets, user submissions)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasDataType a owl:DatatypeProperty ;
    rdfs:label "hasDataType" ;
    skos:definition "The type of data used in the benchmark (e.g., text, images, or multi-modal)" ;
    skos:inScheme nexus:ai_eval .

nexus:hasDomains a owl:DatatypeProperty ;
    rdfs:label "hasDomains" ;
    skos:definition "The specific domains or areas where the benchmark is applied (e.g., natural language processing, computer vision)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasLanguages a owl:DatatypeProperty ;
    rdfs:label "hasLanguages" ;
    skos:definition "The languages included in the dataset used by the benchmark (e.g., English, multilingual)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasLimitations a owl:DatatypeProperty ;
    rdfs:label "hasLimitations" ;
    skos:definition "Limitations in evaluating or addressing risks, such as gaps in demographic coverage or specific domains." ;
    skos:inScheme nexus:ai_eval .

nexus:hasMethods a owl:DatatypeProperty ;
    rdfs:label "hasMethods" ;
    skos:definition "The evaluation techniques applied within the benchmark." ;
    skos:inScheme nexus:ai_eval .

nexus:hasMetrics a owl:DatatypeProperty ;
    rdfs:label "hasMetrics" ;
    skos:definition "The specific performance metrics used to assess models (e.g., accuracy, F1 score, precision, recall)." ;
    skos:inScheme nexus:ai_eval .

nexus:hasResources a owl:DatatypeProperty ;
    rdfs:label "hasResources" ;
    skos:definition "Links to relevant resources, such as repositories or papers related to the benchmark." ;
    skos:inScheme nexus:ai_eval .

nexus:implementedByAdapter a owl:ObjectProperty ;
    rdfs:label "implementedByAdapter" ;
    rdfs:domain nexus:Any ;
    rdfs:range nexus:Any ;
    skos:definition "Indicates that this capability is implemented by a specific adapter. This relationship distinguishes the abstract capability (what can be done) from the technical implementation mechanism (how it is added/extended via adapters)." ;
    skos:inScheme nexus:common .

nexus:isApplicableinLocality a owl:ObjectProperty ;
    rdfs:label "isApplicableinLocality" ;
    rdfs:range nexus:LocalityOfUse ;
    skos:definition "A relationship where an entity has is applicable in these localities." ;
    skos:inScheme nexus:common .

nexus:isComposedOf a owl:DatatypeProperty ;
    rdfs:label "isComposedOf" ;
    skos:definition "Relationship indicating the some entity is composed of other entities (including some of the same type)." ;
    skos:inScheme nexus:common .

nexus:isUsedWithinLocality a owl:ObjectProperty ;
    rdfs:label "isUsedWithinLocality" ;
    rdfs:range nexus:LocalityOfUse ;
    skos:definition "Specifies the domain an AI system is used within." ;
    skos:inScheme nexus:ai_system .

nexus:AIUC1Frequency a owl:Class ;
    rdfs:label "AIUC1Frequency" ;
    owl:unionOf ( <https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_3> <https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_6> <https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_12> ) ;
    skos:inScheme nexus:ai_aiuc ;
    linkml:permissible_values <https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_12>,
        <https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_3>,
        <https://w3id.org/ai-atlas-nexus/AIUC1Frequency#MONTHS_6> .

nexus:AIUC1RequirementType a owl:Class ;
    rdfs:label "AIUC1RequirementType" ;
    owl:unionOf ( <https://w3id.org/ai-atlas-nexus/AIUC1RequirementType#DETECTIVE> <https://w3id.org/ai-atlas-nexus/AIUC1RequirementType#PREVENTATIVE> ) ;
    skos:inScheme nexus:ai_aiuc ;
    linkml:permissible_values <https://w3id.org/ai-atlas-nexus/AIUC1RequirementType#DETECTIVE>,
        <https://w3id.org/ai-atlas-nexus/AIUC1RequirementType#PREVENTATIVE> .

nexus:Action a owl:Class ;
    rdfs:label "Action" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:hasAiActorTask ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasAiActorTask ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        nexus:RiskControl ;
    skos:definition "Action to remediate a risk" ;
    skos:inScheme nexus:ai_risk .

nexus:AdapterType a owl:Class ;
    rdfs:label "AdapterType" ;
    owl:unionOf ( <https://w3id.org/ai-atlas-nexus/AdapterType#LORA> <https://w3id.org/ai-atlas-nexus/AdapterType#ALORA> <https://w3id.org/ai-atlas-nexus/AdapterType#X-LORA> ) ;
    skos:inScheme nexus:ai_intrinsic ;
    linkml:permissible_values <https://w3id.org/ai-atlas-nexus/AdapterType#ALORA>,
        <https://w3id.org/ai-atlas-nexus/AdapterType#LORA>,
        <https://w3id.org/ai-atlas-nexus/AdapterType#X-LORA> .

nexus:CapabilityDomain a owl:Class ;
    rdfs:label "CapabilityDomain" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:CapabilityGroup ;
            owl:onProperty nexus:hasPart ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasPart ],
        nexus:CapabilityConcept,
        nexus:Group ;
    skos:definition "A high-level domain of AI capabilities (e.g., Language, Reasoning, Knowledge)" ;
    skos:exactMatch nexus:CapabilityDomain ;
    skos:inScheme nexus:ai_capability .

nexus:Concept a owl:Class ;
    rdfs:label "Concept" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasJurisdiction ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Jurisdiction ;
            owl:onProperty nexus:hasJurisdiction ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        nexus:Entity ;
    skos:definition "A concept" ;
    skos:exactMatch skos:Concept ;
    skos:inScheme nexus:common .

nexus:Control a owl:Class ;
    rdfs:label "Control" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:LocalityOfUse ;
            owl:onProperty nexus:isApplicableinLocality ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isApplicableinLocality ],
        nexus:Entity ;
    skos:definition "A measure that maintains and/or modifies" ;
    skos:exactMatch nexus:Control ;
    skos:inScheme nexus:common .

nexus:Dataset a owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:provider ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:License ;
