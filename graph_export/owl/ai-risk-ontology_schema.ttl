    skos:definition "A generic grouping for any identifiable entity." ;
    skos:exactMatch <http://schema.org/Thing> ;
    skos:inScheme nexus:common .

nexus:hasDocumentation a owl:ObjectProperty ;
    rdfs:label "hasDocumentation" ;
