            owl:onProperty nexus:requiresCapability ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRule ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Taxonomy ;
            owl:onProperty nexus:isDefinedByTaxonomy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Rule ;
            owl:onProperty nexus:hasRule ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Capability ;
            owl:onProperty nexus:requiresCapability ],
        nexus:Entity ;
    skos:definition "An entry and its definitions." ;
    skos:exactMatch nexus:Entry ;
    skos:inScheme nexus:common .

nexus:Capability a owl:Class ;
    rdfs:label "Capability" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:requiredByTask ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:AiTask ;
            owl:onProperty nexus:requiredByTask ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:CapabilityGroup ;
            owl:onProperty nexus:isPartOf ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Adapter ;
            owl:onProperty nexus:implementedByAdapter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:implementedByAdapter ],
        nexus:CapabilityConcept,
        nexus:Entry ;
    skos:broadMatch <https://w3id.org/dpv/tech#Capability> ;
    skos:definition """A specific AI capability or ability, such as reading comprehension, logical reasoning, or code generation. Aligned with the W3C DPV AI extension dpv-ai:Capability, representing what an AI technology is capable of achieving or providing.
Capabilities are distinct from: (1) the intended purpose for which the technology is designed, (2) the actual tasks performed in a specific deployment context, and (3) the technical implementation mechanisms (intrinsics, adapters) that enable the capability.""" ;
    skos:exactMatch <https://w3id.org/dpv/ai#Capability> ;
    skos:inScheme nexus:ai_capability .

nexus:hasRelatedRisk a owl:ObjectProperty ;
    rdfs:label "hasRelatedRisk" ;
    rdfs:domain nexus:Any ;
    rdfs:range [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
    skos:definition "A relationship where an entity relates to a risk" ;
    skos:inScheme nexus:ai_risk .

nexus:version a owl:DatatypeProperty ;
    rdfs:label "version" ;
    skos:definition "The version of the entity embodied by a specified resource." ;
    skos:inScheme nexus:common .

nexus:Documentation a owl:Class ;
    rdfs:label "Documentation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:author ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:License ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:author ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:author ],
        nexus:Entity ;
    skos:definition "Documented information about a concept or other topic(s) of interest." ;
    skos:exactMatch airo:Documentation ;
    skos:inScheme nexus:common .

nexus:Term a owl:Class ;
    rdfs:label "Term" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom [ owl:intersectionOf ( [ owl:unionOf ( nexus:RiskConcept nexus:Term ) ] nexus:Risk ) ] ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasParentDefinition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasSubDefinition ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Term ;
            owl:onProperty nexus:hasSubDefinition ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasRelatedRisk ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Vocabulary ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDefinedByVocabulary ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Term ;
            owl:onProperty nexus:hasParentDefinition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        nexus:Entry ;
    skos:definition "A term and its definitions." ;
    skos:inScheme nexus:common .

nexus:isPartOf a owl:DatatypeProperty ;
    rdfs:label "isPartOf" ;
    skos:definition "A relationship where an entity is part of another entity" ;
    skos:inScheme nexus:common .

nexus:Any a owl:Class ;
    rdfs:label "Any" ;
    skos:exactMatch linkml:Any ;
    skos:inScheme nexus:ai_risk .

nexus:Taxonomy a owl:Class ;
    rdfs:label "Taxonomy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:version ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:License ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nexus:version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nexus:hasLicense ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:Documentation ;
            owl:onProperty nexus:hasDocumentation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:version ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:hasLicense ],
        nexus:Entity ;
    skos:definition "A hierachical taxonomy of concepts, with their definitions and relationships." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme nexus:common .

nexus:RiskConcept a owl:Class ;
    rdfs:label "RiskConcept" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nexus:LocalityOfUse ;
            owl:onProperty nexus:isUsedWithinLocality ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isDetectedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isMitigatedBy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nexus:isUsedWithinLocality ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:RiskControl ;
            owl:onProperty nexus:isDetectedBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom nexus:RiskControl ;
            owl:onProperty nexus:isMitigatedBy ],
        nexus:Concept ;
    skos:definition "An umbrella term for referring to risk, risk source, consequence and impact." ;
    skos:exactMatch airo:RiskConcept ;
    skos:inScheme nexus:ai_risk .

nexus:hasLicense a owl:ObjectProperty ;
    rdfs:label "hasLicense" ;
    rdfs:range nexus:License ;
    skos:definition "Indicates licenses associated with a resource" ;
    skos:inScheme nexus:common .

